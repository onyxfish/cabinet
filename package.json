{
  "name": "cabinet",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "sync": "tsx scripts/sync.ts",
    "enrich:lookup": "tsx scripts/enrich-lookup.ts",
    "enrich:apply": "tsx scripts/enrich-apply.ts",
    "dev": "astro dev",
    "build": "astro build && pagefind --site dist",
    "preview": "astro build && wrangler pages dev",
    "deploy": "pnpm build && wrangler pages deploy",
    "astro": "astro",
    "generate-types": "wrangler types"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.3.0",
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/svelte": "^8.1.0",
    "astro": "^6.2.1",
    "svelte": "^5.55.5"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1041.0",
    "@aws-sdk/lib-storage": "^3.1041.0",
    "@types/node": "^25.6.0",
    "dotenv": "^17.4.2",
    "gray-matter": "^4.0.3",
    "pagefind": "^1.5.2",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "wrangler": "^4.88.0"
  },
  "overrides": {
    "vite": "^7"
  },
  "pnpm": {
